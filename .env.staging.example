# Copy to `.env.staging` on the staging server (do not commit secrets).

# Public URL of the app (must be https if behind a TLS-terminating proxy).
APP_URL=https://www.trtechapp.com

# Trust proxy headers (X-Forwarded-For/Proto). Recommended behind Apache/nginx.
# Set to `false` only if the app is directly exposed to the internet.
TRUST_PROXY=true

# Database (managed DB recommended for staging)
# Example (URL-encode password if it contains special characters):
# DATABASE_URL=postgresql://doadmin:%3Cpassword%3E@db-host:25060/defaultdb?sslmode=require
DATABASE_URL=

# Required secrets
SESSION_SECRET=replace-with-long-random
ADMIN_TOKEN=replace-with-long-random

# Optional: bind the container port to the host
# - If you already have a reverse proxy on the host (nginx/traefik/caddy), keep `127.0.0.1`.
# - If you want to expose the app directly (not recommended), set `0.0.0.0`.
#
# IMPORTANT: these values are used by Docker Compose for port mappings, so run compose with:
# `docker compose --env-file .env.staging -f docker-compose.staging.yml ...`
APP_BIND_IP=127.0.0.1
APP_HOST_PORT=3000

# Caddy (only used if you run: --profile caddy)
CADDY_HOST=www.trtechapp.com
CADDY_EMAIL=replace-with-you@example.com

# SMTP (optional; if unset, emails are logged)
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# If your staging server uses a local MTA (sendmail/postfix), you can relay via the host:
# - Ensure the host is listening on 127.0.0.1:25 (or another port) and allows relay from Docker.
# - Then set:
# SMTP_HOST=host.docker.internal
# SMTP_PORT=25
# SMTP_SECURE=false
