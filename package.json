{
  "name": "volunteerflow",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "migrate": "node scripts/run.mjs migrate",
    "seed": "node scripts/run.mjs seed",
    "set-password": "node scripts/run.mjs set-password",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.0",
    "@fastify/formbody": "^8.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/view": "^10.0.0",
    "fastify": "^5.0.0",
    "kysely": "^0.28.0",
    "nodemailer": "^6.9.15",
    "nunjucks": "^3.2.4",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.16",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  }
}
