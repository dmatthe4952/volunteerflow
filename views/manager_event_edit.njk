{% extends "layout.njk" %}
{% block content %}
  <h1>Edit Event</h1>
  <div class="crumbs">
    <a href="/manager/events">My events</a>
    <span class="sep">/</span>
    <span>{{ event.title }}</span>
  </div>

  {% if error %}
    <div class="flash err"><div>{{ error }}</div></div>
  {% endif %}
  {% if ok %}
    <div class="flash ok"><div>{{ ok }}</div></div>
  {% endif %}

  {% if event.isArchived %}
    <div class="flash err">
      <div><strong>Event archived.</strong> This event is hidden from the public site and not accepting new signups.</div>
    </div>
  {% endif %}

  {% if event.cancelledAt %}
    <div class="flash err">
      <div><strong>Event cancelled.</strong> {% if event.cancellationMessage %}{{ event.cancellationMessage }}{% endif %}</div>
    </div>
  {% endif %}

  <div class="panel">
    <div class="title">Event image</div>
    <img class="event-hero" src="{{ event.imagePath }}" alt="{{ event.title }}" style="margin-top:12px" />
    {% if event.hasCustomImage %}
      <form method="post" action="/manager/events/{{ event.id }}/image/clear" style="margin-top:12px">
      <input type="hidden" name="csrfToken" value="{{ csrfToken }}" />
        <button class="btn danger" type="submit">Remove image</button>
      </form>
    {% else %}
      <p class="muted" style="margin-top:8px">Using the default image.</p>
    {% endif %}
    <form class="form" method="post" action="/manager/events/{{ event.id }}/image" enctype="multipart/form-data">
      <input type="hidden" name="csrfToken" value="{{ csrfToken }}" />
      <label>
        <span>Upload image</span>
        <input name="image" type="file" accept="image/png,image/jpeg,image/webp,image/gif" required />
      </label>
      <div class="actions">
        <button class="btn primary" type="submit">{% if event.hasCustomImage %}Replace image{% else %}Upload image{% endif %}</button>
      </div>
    </form>
  </div>

  <div class="panel">
    <form class="form" method="post" action="/manager/events/{{ event.id }}/edit">
      <input type="hidden" name="csrfToken" value="{{ csrfToken }}" />
      <label>
        <span>Title</span>
        <input name="title" required maxlength="200" value="{{ event.title }}" />
      </label>
      <label>
        <span>Organization</span>
        <select name="organizationId" required>
          {% for o in orgs %}
            <option value="{{ o.id }}" {% if o.id == event.organizationId %}selected{% endif %}>{{ o.name }}</option>
          {% endfor %}
        </select>
      </label>
      <label>
        <span>Featured?</span>
        <input type="checkbox" name="isFeatured" {% if event.isFeatured %}checked{% endif %} />
      </label>
      <label>
        <span>Tags (comma-separated)</span>
        <input name="tags" maxlength="500" value="{{ event.tags }}" placeholder="e.g. food, outdoors, community" />
      </label>
      <div class="grid2">
        <label>
          <span>Start date</span>
          <input name="startDate" type="date" required value="{{ event.startDate }}" />
        </label>
        <label>
          <span>End date</span>
          <input name="endDate" type="date" required value="{{ event.endDate }}" />
        </label>
      </div>
      <label>
        <span>Purge window (days, optional)</span>
        {% if event.isPublished %}
          <input type="number" value="{% if event.purgeAfterDays != null %}{{ event.purgeAfterDays }}{% endif %}" disabled />
          <input type="hidden" name="purgeAfterDays" value="{% if event.purgeAfterDays != null %}{{ event.purgeAfterDays }}{% endif %}" />
        {% else %}
          <input name="purgeAfterDays" type="number" min="0" max="3650" step="1" value="{% if event.purgeAfterDays != null %}{{ event.purgeAfterDays }}{% endif %}" placeholder="{{ defaultPurgeAfterDays }}" />
        {% endif %}
      </label>
      {% if event.isPublished %}
        <p class="muted" style="margin-top:-6px">This event is published. Ask an admin to change the purge window.</p>
      {% else %}
        <p class="muted" style="margin-top:-6px">Leave blank to use the system default (currently {{ defaultPurgeAfterDays }} days).</p>
      {% endif %}
      <label>
        <span>Description</span>
        <textarea name="description" rows="6">{{ event.description }}</textarea>
      </label>
      <label>
        <span>Confirmation email note (optional)</span>
        <textarea name="confirmationEmailNote" rows="4" maxlength="2000" placeholder="This message will be included in the volunteer’s signup confirmation email.">{{ event.confirmationEmailNote }}</textarea>
      </label>
      <div class="grid2">
        <label>
          <span>Location name</span>
          <input name="locationName" maxlength="200" value="{{ event.locationName }}" />
        </label>
        <label>
          <span>Google Maps URL</span>
          <input name="locationMapUrl" maxlength="500" value="{{ event.locationMapUrl }}" />
        </label>
      </div>
      <div class="actions">
        <button class="btn primary" type="submit">Save</button>
        <a class="btn" href="/manager/events/{{ event.id }}/signups">View Signups</a>
        <a class="btn" href="/manager/events/{{ event.id }}/broadcast">Broadcast</a>
        {% if not event.isArchived %}
          {% if event.isPublished %}
            <button class="btn" formmethod="post" formaction="/manager/events/{{ event.id }}/unpublish" type="submit">Unpublish</button>
          {% else %}
            <button class="btn" formmethod="post" formaction="/manager/events/{{ event.id }}/publish" type="submit">Publish</button>
          {% endif %}
        {% endif %}
        {% if event.isArchived %}
          <button class="btn" formmethod="post" formaction="/manager/events/{{ event.id }}/unarchive" type="submit">Unarchive</button>
        {% else %}
          <button class="btn danger" formmethod="post" formaction="/manager/events/{{ event.id }}/archive" type="submit">Archive</button>
        {% endif %}
        {% if (not event.cancelledAt) and (not event.isArchived) %}
          <a class="btn danger" href="/manager/events/{{ event.id }}/cancel">Cancel Event</a>
        {% endif %}
      </div>
    </form>
  </div>

  <h2 style="margin-top:18px">Shifts</h2>
  {% if shifts.length == 0 %}
    <div class="panel"><p class="muted">No shifts yet. Add one below.</p></div>
  {% else %}
    <div class="stack">
      {% for s in shifts %}
        <div class="panel" id="shift-{{ s.id }}">
          <div class="title">{{ s.roleName }}</div>
          <div class="meta">{{ s.shiftDate }} • {{ s.startTime }} – {{ s.endTime }}</div>
          <div class="muted" style="margin-top:8px">
            Capacity: {{ s.maxVolunteers }} (min {{ s.minVolunteers }})
            {% if not s.isActive %} • Inactive{% endif %}
          </div>
          <div class="actions" style="margin-top:12px">
            <form method="post" action="/manager/shifts/{{ s.id }}/toggle" style="display:inline">
      <input type="hidden" name="csrfToken" value="{{ csrfToken }}" />
              <button class="btn" type="submit">{% if s.isActive %}Deactivate{% else %}Activate{% endif %}</button>
            </form>
            <details style="display:inline">
              <summary class="btn">Edit</summary>
              <form class="form" method="post" action="/manager/shifts/{{ s.id }}/update">
      <input type="hidden" name="csrfToken" value="{{ csrfToken }}" />
                <input type="hidden" name="eventId" value="{{ event.id }}" />
                <div class="grid2">
                  <label>
                    <span>Role name</span>
                    <input name="roleName" required maxlength="120" value="{{ s.roleName }}" />
                  </label>
                  <label>
                    <span>Date</span>
                    <input name="shiftDate" type="date" required value="{{ s.shiftDate }}" />
                  </label>
                </div>
                <label>
                  <span>Role description</span>
                  <input name="roleDescription" maxlength="500" value="{{ s.roleDescription }}" />
                </label>
                <div class="grid2">
                  <label>
                    <span>Start time</span>
                    <input name="startTime" type="time" required value="{{ s.startTime }}" />
                  </label>
                  <label>
                    <span>Duration (minutes)</span>
                    <input name="durationMinutes" type="number" min="15" step="15" required value="{{ s.durationMinutes }}" />
                  </label>
                </div>
                <div class="grid2">
                  <label>
                    <span>Min volunteers</span>
                    <input name="minVolunteers" type="number" min="0" step="1" required value="{{ s.minVolunteers }}" />
                  </label>
                  <label>
                    <span>Max volunteers</span>
                    <input name="maxVolunteers" type="number" min="1" step="1" required value="{{ s.maxVolunteers }}" />
                  </label>
                </div>
                <div class="actions">
                  <button class="btn primary" type="submit">Save Shift</button>
                </div>
              </form>
            </details>
            <form method="post" action="/manager/shifts/{{ s.id }}/delete" style="display:inline">
      <input type="hidden" name="csrfToken" value="{{ csrfToken }}" />
              <input type="hidden" name="eventId" value="{{ event.id }}" />
              <button class="btn danger" type="submit">Delete</button>
            </form>
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}

  <h2 style="margin-top:18px">Add Shift</h2>
  <div class="panel">
    <form class="form" method="post" action="/manager/events/{{ event.id }}/shifts">
      <input type="hidden" name="csrfToken" value="{{ csrfToken }}" />
      <div class="grid2">
        <label>
          <span>Role name</span>
          <input name="roleName" required maxlength="120" />
        </label>
        <label>
          <span>Date</span>
          <input name="shiftDate" type="date" required value="{{ event.startDate }}" />
        </label>
      </div>
      <label>
        <span>Role description</span>
        <input name="roleDescription" maxlength="500" />
      </label>
      <div class="grid2">
        <label>
          <span>Start time</span>
          <input name="startTime" type="time" required />
        </label>
        <label>
          <span>Duration (minutes)</span>
          <input name="durationMinutes" type="number" min="15" step="15" required value="60" />
        </label>
      </div>
      <div class="grid2">
        <label>
          <span>Min volunteers</span>
          <input name="minVolunteers" type="number" min="0" step="1" required value="0" />
        </label>
        <label>
          <span>Max volunteers</span>
          <input name="maxVolunteers" type="number" min="1" step="1" required value="1" />
        </label>
      </div>
      <div class="actions">
        <button class="btn primary" type="submit">Add Shift</button>
      </div>
    </form>
  </div>

  {% if templates and templates.length > 0 %}
    <h2 style="margin-top:18px">Add Shift From Template</h2>
    <div class="panel">
      <form class="form" method="post" action="/manager/events/{{ event.id }}/shifts/from-template">
      <input type="hidden" name="csrfToken" value="{{ csrfToken }}" />
        <label>
          <span>Template</span>
          <select name="templateId" required>
            {% for t in templates %}
              <option value="{{ t.id }}">{{ t.roleName }} ({{ t.durationMinutes }}m • min {{ t.minVolunteers }} • max {{ t.maxVolunteers }})</option>
            {% endfor %}
          </select>
        </label>
        <div class="grid2">
          <label>
            <span>Date</span>
            <input name="shiftDate" type="date" required value="{{ event.startDate }}" />
          </label>
          <label>
            <span>Start time</span>
            <input name="startTime" type="time" required />
          </label>
        </div>
        <div class="actions">
          <button class="btn primary" type="submit">Add From Template</button>
          <a class="btn" href="/manager/templates">Manage Templates</a>
        </div>
      </form>
    </div>
  {% else %}
    <div class="panel" style="margin-top:18px">
      <div class="title">Shift Templates</div>
      <p class="muted" style="margin-top:8px">Save common roles (duration + min/max) to add shifts faster.</p>
      <div class="actions" style="margin-top:12px">
        <a class="btn" href="/manager/templates">Create a template</a>
      </div>
    </div>
  {% endif %}

  <h2 style="margin-top:18px">Reminder Rules</h2>
  <div class="panel">
    <p class="muted">Set up to 3 reminder rules per event. Offsets are in hours before shift start.</p>
    {% if reminderRules and reminderRules.length > 0 %}
      <div class="stack" style="margin-top:12px">
        {% for r in reminderRules %}
          <details class="panel" style="margin:0">
            <summary style="cursor:pointer">
              <strong>{{ r.sendOffsetHours }}h</strong>
              {% if r.isActive %}
                <span class="badge" style="margin-left:8px">Active</span>
              {% else %}
                <span class="badge" style="margin-left:8px">Inactive</span>
              {% endif %}
              <span class="muted" style="margin-left:8px">{{ r.subjectTemplate }}</span>
            </summary>
            <form class="form" method="post" action="/manager/events/{{ event.id }}/reminder-rules/{{ r.id }}/update" style="margin-top:10px">
              <input type="hidden" name="csrfToken" value="{{ csrfToken }}" />
              <div class="grid2">
                <label>
                  <span>Offset (hours)</span>
                  <input name="sendOffsetHours" type="number" min="0" max="336" step="1" required value="{{ r.sendOffsetHours }}" />
                </label>
                <label>
                  <span>Active?</span>
                  <input name="isActive" type="checkbox" {% if r.isActive %}checked{% endif %} />
                </label>
              </div>
              <label>
                <span>Subject template</span>
                <input name="subjectTemplate" maxlength="300" required value="{{ r.subjectTemplate }}" />
              </label>
              <label>
                <span>Body template</span>
                <textarea name="bodyTemplate" rows="4" maxlength="20000" required>{{ r.bodyTemplate }}</textarea>
              </label>
              <div class="actions">
                <button class="btn primary" type="submit">Save Rule</button>
              </div>
            </form>
            <form method="post" action="/manager/events/{{ event.id }}/reminder-rules/{{ r.id }}/delete" style="margin-top:10px">
              <input type="hidden" name="csrfToken" value="{{ csrfToken }}" />
              <button class="btn danger" type="submit">Delete Rule</button>
            </form>
          </details>
        {% endfor %}
      </div>
    {% endif %}

    {% if (not reminderRules) or reminderRules.length < 3 %}
      <form class="form" method="post" action="/manager/events/{{ event.id }}/reminder-rules" style="margin-top:14px">
        <input type="hidden" name="csrfToken" value="{{ csrfToken }}" />
        <div class="grid2">
          <label>
            <span>Offset (hours)</span>
            <input name="sendOffsetHours" type="number" min="0" max="336" step="1" required value="24" />
          </label>
          <label>
            <span>Active?</span>
            <input name="isActive" type="checkbox" checked />
          </label>
        </div>
        <label>
          <span>Subject template</span>
          <input name="subjectTemplate" maxlength="300" required value="Reminder: {{event_title}} ({{shift_date}} {{shift_start_time}})" />
        </label>
        <label>
          <span>Body template</span>
          <textarea name="bodyTemplate" rows="4" maxlength="20000" required>Hi {{volunteer_first_name}},

This is a reminder for your upcoming shift: {{shift_role}} at {{event_title}}.

When: {{shift_date}} {{shift_start_time}} - {{shift_end_time}}
Where: {{location_name}}
Event page: {{event_url}}
Cancel: {{cancel_url}}

- LocalShifts</textarea>
        </label>
        <div class="actions">
          <button class="btn primary" type="submit">Add Reminder Rule</button>
        </div>
      </form>
    {% else %}
      <p class="muted" style="margin-top:12px">Maximum reached (3 rules).</p>
    {% endif %}
  </div>
{% endblock %}
