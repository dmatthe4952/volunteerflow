{% extends "layout.njk" %}
{% block content %}
  <div class="bb">
    <h1>Make a Difference</h1>
    <p class="half-back">Sign up for a shift -- no account required.</p>
  </div>
  <h3>Upcoming Volunteer Opportunities</h3>
  {% if events.length == 0 %}
    <div class="panel">
      <p class="muted">No published events yet.</p>
      {% if showSeedHint %}
        <p class="muted">Seed demo data: <code>docker compose exec app npm run seed</code></p>
      {% endif %}
    </div>
  {% else %}
    <div class="grid">
      {% for event in events %}
        <a class="card {% if event.category and event.category != 'normal' %}cat-{{ event.category }}{% endif %}" href="{{ event.url }}">
          <img class="card-img" src="{{ event.imagePath }}" alt="{{ event.title }}" />
          <div class="card-hd">
            <div class="title">{{ event.title }}</div>
          </div>
          <div class="card-bd">
            <div class="card-meta">
              <div class="card-date">{{ event.dateRange }}</div>
              {% if event.category == 'featured' %}
                <span class="badge featured">Featured</span>
              {% elseif event.category == 'understaffed' %}
                <span class="badge danger">Understaffed</span>
              {% endif %}
            </div>
            {% if event.timeLabel %}
              <div class="card-time" aria-label="Time">
                <svg class="icon-clock" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <circle cx="12" cy="12" r="9"></circle>
                  <path d="M12 7v6l4 2"></path>
                </svg>
                <span>{{ event.timeLabel }}</span>
              </div>
            {% endif %}
            {% if event.description %}
              <div class="card-desc">{{ event.description }}</div>
            {% endif %}
            <div class="card-cta" aria-hidden="true">View Shifts & Sign Up</div>
          </div>
        </a>
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
