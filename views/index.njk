{% extends "layout.njk" %}
{% block content %}
  <div class="bb">
    <h1>Make a Difference</h1>
    <p class="half-back">Sign up for a shift -- no account required.</p>
  </div>
  <div class="panel" style="margin-bottom:12px">
    {% if locationContext and locationContext.hasActiveFilter %}
      <p class="muted" style="margin:0 0 10px">
        Showing events near {{ locationContext.label or 'your area' }}
        {% if locationContext.radiusMiles == null %}
          (all distances)
        {% else %}
          (within {{ locationContext.radiusMiles }} miles)
        {% endif %}
        — <a href="/?loc=clear{% if tag %}&tag={{ tag | urlencode }}{% endif %}{% if selectedOrg %}&org={{ selectedOrg | urlencode }}{% endif %}">change location</a>
      </p>
    {% endif %}
    <form class="form" method="get" action="/">
      {% if tag %}
        <input type="hidden" name="tag" value="{{ tag }}" />
      {% endif %}
      {% if selectedOrg and (not orgOptions or orgOptions.length <= 1) %}
        <input type="hidden" name="org" value="{{ selectedOrg }}" />
      {% endif %}
      <div class="grid2">
        <label>
          <span>ZIP code</span>
          <input name="zip" inputmode="numeric" pattern="[0-9]{5}" maxlength="5" placeholder="e.g. 10001" value="{{ (locationContext and locationContext.zip) or '' }}" />
        </label>
        <label>
          <span>Radius</span>
          <select name="radius">
            {% set selectedRadius = (locationContext and locationContext.radiusMiles) %}
            <option value="5" {% if selectedRadius == 5 %}selected{% endif %}>5 miles</option>
            <option value="10" {% if selectedRadius == 10 %}selected{% endif %}>10 miles</option>
            <option value="20" {% if selectedRadius == 20 %}selected{% endif %}>20 miles</option>
            <option value="50" {% if selectedRadius == 50 %}selected{% endif %}>50 miles</option>
            <option value="all" {% if selectedRadius == null %}selected{% endif %}>Show all</option>
          </select>
        </label>
      </div>
      {% if orgOptions and orgOptions.length > 1 %}
        <label>
          <span>Organization</span>
          <select name="org">
            <option value="" {% if not selectedOrg %}selected{% endif %}>All organizations</option>
            {% for org in orgOptions %}
              <option value="{{ org.slug }}" {% if selectedOrg == org.slug %}selected{% endif %}>{{ org.name }}</option>
            {% endfor %}
          </select>
        </label>
      {% endif %}
      <div class="actions">
        <button class="btn primary" type="submit">Apply Location</button>
        <button class="btn" id="use-my-location" type="button">Use My Current Location</button>
      </div>
    </form>
  </div>
  <h3>Upcoming Volunteer Opportunities</h3>
  {% if pastEventsEnabled %}
    <p class="muted" style="margin-top:-6px"><a href="/events/past">Browse past events</a></p>
  {% endif %}
  {% if featuredEvents.length == 0 and otherEvents.length == 0 %}
    <div class="panel">
      <p class="muted">No published events yet.</p>
      {% if showSeedHint %}
        <p class="muted">Seed demo data: <code>docker compose exec app npm run seed</code></p>
      {% endif %}
    </div>
  {% else %}
    {% if featuredEvents.length > 0 %}
      <h3 style="margin-top:14px">Featured</h3>
      <div class="grid">
        {% for event in featuredEvents %}
          <a class="card cat-featured" href="{{ event.url }}">
            <img class="card-img" src="{{ event.imagePath }}" alt="{{ event.title }}" />
            <div class="card-hd">
              <div class="title">{{ event.title }}</div>
            </div>
            <div class="card-bd">
              <div class="card-meta">
                <div class="card-date">{{ event.dateRange }}</div>
                <div class="right" style="gap:6px; flex-wrap:wrap; justify-content:flex-end">
                  {% if event.isFull %}
                    <span class="badge">Full</span>
                  {% endif %}
                  {% if event.distanceMiles != null %}
                    <span class="badge">{{ event.distanceMiles }} mi</span>
                  {% endif %}
                  <span class="badge featured">Featured</span>
                  {% for t in event.tags %}
                    <span class="badge tag">{{ t }}</span>
                  {% endfor %}
                </div>
              </div>
              {% if event.timeLabel %}
                <div class="card-time" aria-label="Time">
                  <svg class="icon-clock" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <circle cx="12" cy="12" r="9"></circle>
                    <path d="M12 7v6l4 2"></path>
                  </svg>
                  <span>{{ event.timeLabel }}</span>
                </div>
              {% endif %}
              {% if event.descriptionHtml %}
                <div class="card-desc">{{ event.descriptionHtml | safe }}</div>
              {% elseif event.description %}
                <div class="card-desc">{{ event.description }}</div>
              {% endif %}
              <div class="card-cta" aria-hidden="true">View Shifts & Sign Up</div>
            </div>
          </a>
        {% endfor %}
      </div>
    {% endif %}

    {% if otherEvents.length > 0 %}
      <h3 style="margin-top:14px">All Events</h3>
      <div class="grid">
        {% for event in otherEvents %}
          <a class="card" href="{{ event.url }}">
            <img class="card-img" src="{{ event.imagePath }}" alt="{{ event.title }}" />
            <div class="card-hd">
              <div class="title">{{ event.title }}</div>
            </div>
            <div class="card-bd">
              <div class="card-meta">
                <div class="card-date">{{ event.dateRange }}</div>
                <div class="right" style="gap:6px; flex-wrap:wrap; justify-content:flex-end">
                  {% if event.isFull %}
                    <span class="badge">Full</span>
                  {% endif %}
                  {% if event.distanceMiles != null %}
                    <span class="badge">{{ event.distanceMiles }} mi</span>
                  {% endif %}
                  {% for t in event.tags %}
                    <span class="badge tag">{{ t }}</span>
                  {% endfor %}
                </div>
              </div>
              {% if event.timeLabel %}
                <div class="card-time" aria-label="Time">
                  <svg class="icon-clock" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <circle cx="12" cy="12" r="9"></circle>
                    <path d="M12 7v6l4 2"></path>
                  </svg>
                  <span>{{ event.timeLabel }}</span>
                </div>
              {% endif %}
              {% if event.descriptionHtml %}
                <div class="card-desc">{{ event.descriptionHtml | safe }}</div>
              {% elseif event.description %}
                <div class="card-desc">{{ event.description }}</div>
              {% endif %}
              <div class="card-cta" aria-hidden="true">View Shifts & Sign Up</div>
            </div>
          </a>
        {% endfor %}
      </div>
    {% endif %}
  {% endif %}
  <script>
    (function () {
      var btn = document.getElementById('use-my-location');
      if (!btn) return;
      btn.addEventListener('click', function () {
        if (!navigator.geolocation) return;
        btn.disabled = true;
        navigator.geolocation.getCurrentPosition(
          function (pos) {
            var params = new URLSearchParams(window.location.search);
            params.set('lat', String(pos.coords.latitude));
            params.set('lng', String(pos.coords.longitude));
            if (!params.get('radius')) params.set('radius', '20');
            params.delete('zip');
            params.delete('loc');
            window.location.href = '/?' + params.toString();
          },
          function () {
            btn.disabled = false;
          },
          { enableHighAccuracy: false, timeout: 8000, maximumAge: 300000 }
        );
      });
    })();
  </script>
{% endblock %}
