{% extends "layout.njk" %}
{% block content %}
  <div class="crumbs">
    <a href="/">All events</a>
    <span class="sep">/</span>
    <span>{{ event.title }}</span>
  </div>

  <div class="panel">
    {% if event.imagePath %}
      <img class="event-hero" src="{{ event.imagePath }}" alt="{{ event.title }}" />
    {% endif %}
    <h1>{{ event.title }}</h1>
    <div class="meta">{{ event.organizationName }} • {{ event.dateRange }}</div>

    {% if event.cancelledAt %}
      <div class="flash err" style="margin-top:14px">
        <div><strong>This event has been cancelled.</strong> {% if event.cancellationMessage %}{{ event.cancellationMessage }}{% endif %}</div>
      </div>
    {% endif %}

    {% if event.locationName %}
      <div class="row">
        <span class="label">Location</span>
        <span class="value">
          {{ event.locationName }}
          {% if event.locationMapUrl %}
            <span class="sep">·</span>
            <a href="{{ event.locationMapUrl }}" target="_blank" rel="noopener">View on Google Maps</a>
          {% endif %}
        </span>
      </div>
    {% endif %}

    {% if event.descriptionHtml %}
      <div class="prose">{{ event.descriptionHtml | safe }}</div>
    {% endif %}
  </div>

  {% if flash %}
    <div class="flash {{ flash.type }}">
      <div>{{ flash.message }}</div>
    </div>
  {% endif %}

  <h2>Shifts</h2>
  {% if event.shifts.length == 0 %}
    <div class="panel"><p class="muted">No active shifts for this event.</p></div>
  {% else %}
    <div class="stack">
      {% for shift in event.shifts %}
        <div class="panel {% if flash and flash.type == 'err' and flash.shiftId and flash.shiftId == shift.id %}attn{% endif %}" id="shift-{{ shift.id }}">
          {% if flash and flash.type == 'err' and flash.shiftId and flash.shiftId == shift.id %}
            <div class="flash err" style="margin:0 0 12px">
              <div>{{ flash.message }}</div>
            </div>
          {% endif %}
          <div class="shift-top">
            <div>
              <div class="title">{{ shift.roleName }}</div>
              <div class="meta">{{ shift.date }} • {{ shift.startTime }} – {{ shift.endTime }}</div>
              {% if shift.roleDescription %}
                <div class="muted" style="margin-top:6px">{{ shift.roleDescription }}</div>
              {% endif %}
            </div>
            <div class="right">
              {% if shift.isFull %}
                <div class="badge danger">Full</div>
              {% else %}
                <div class="badge ok">{{ shift.remaining }} open</div>
              {% endif %}
            </div>
          </div>

          <div class="shift-actions">
            {% if shift.viewerSignup.isSignedUp %}
              <div class="muted">
                You’re signed up.
                {% if shift.viewerSignup.cancelUrl %}
                  <a href="{{ shift.viewerSignup.cancelUrl }}">Cancel</a>
                {% endif %}
              </div>
            {% endif %}
            {% if event.cancelledAt %}
              <span class="btn" aria-disabled="true">Event Cancelled</span>
            {% elseif shift.isFull %}
              <span class="btn" aria-disabled="true">Shift Full</span>
            {% elseif shift.viewerSignup.isSignedUp %}
              <span class="btn" aria-disabled="true">Signed Up</span>
            {% else %}
              <details>
                <summary class="btn">Sign Me Up</summary>
                <form class="form" method="post" action="{{ event.url }}/shifts/{{ shift.id }}/signup">
                  <div class="grid2">
                    <label>
                      <span>First name</span>
                      <input name="firstName" autocomplete="given-name" required data-vf="firstName" />
                    </label>
                    <label>
                      <span>Last name</span>
                      <input name="lastName" autocomplete="family-name" required data-vf="lastName" />
                    </label>
                  </div>
                  <label>
                    <span>Email</span>
                    <input name="email" type="email" autocomplete="email" required data-vf="email" value="{{ viewerEmail or '' }}" />
                  </label>
                  <div class="actions">
                    <button class="btn primary" type="submit">Confirm Signup</button>
                  </div>
                </form>
              </details>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}

  <script>
    (function () {
      try {
        var panels = document.querySelectorAll('[id^="shift-"]');
        panels.forEach(function (panel) {
          var form = panel.querySelector('form.form');
          if (!form) return;
          var first = form.querySelector('input[data-vf="firstName"]');
          var last = form.querySelector('input[data-vf="lastName"]');
          var email = form.querySelector('input[data-vf="email"]');

          if (first && !first.value) first.value = localStorage.getItem('vf_firstName') || '';
          if (last && !last.value) last.value = localStorage.getItem('vf_lastName') || '';
          if (email && !email.value) email.value = localStorage.getItem('vf_email') || '';

          if (first) first.addEventListener('input', function () { localStorage.setItem('vf_firstName', first.value); });
          if (last) last.addEventListener('input', function () { localStorage.setItem('vf_lastName', last.value); });
          if (email) email.addEventListener('input', function () { localStorage.setItem('vf_email', email.value); });
        });

        var flashShiftId = {{ ((flash and flash.shiftId) or null) | dump }};
        if (flashShiftId) {
          var panel = document.getElementById('shift-' + flashShiftId);
          if (panel) {
            var details = panel.querySelector('details');
            if (details) details.open = true;
            var focusInput = panel.querySelector('input[name="firstName"], input[name="email"]');
            if (focusInput && typeof focusInput.focus === 'function') focusInput.focus();
          }
        }
      } catch (e) {}
    })();
  </script>
{% endblock %}
