<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>LocalShifts</title>
    <link rel="stylesheet" href="/public/styles.css" />
    <link rel="icon" type="image/x-icon" href="public/favicon.ico">
  </head>
  <body>
    <header class="topbar">
      <div class="wrap">
        <nav class="nav">
          <a href="/" class="brand" aria-label="LocalShifts">
            <img class="brand-logo" src="/public/images/official_logo.png" alt="VolunteerFlow" />
          </a>
          <div class="nav-links">
            {% if navTags %}
              <div class="nav-dd">
                <a class="nav-dd-trigger" href="/" aria-label="Filter events by tag">
                  <svg class="icon-funnel" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M3 5h18l-7 8v5l-4 2v-7z"></path>
                  </svg>
                  <span>{% if tag %}Tag: {{ tag }}{% else %}All Volunteer Events{% endif %}</span>
                  <svg class="icon-caret" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M7 10l5 5 5-5"></path>
                  </svg>
                </a>
                <div class="nav-dd-menu" role="menu" aria-label="Event tags">
                  <a class="nav-dd-item" role="menuitem" href="/">All Events</a>
                  {% for t in navTags %}
                    <a class="nav-dd-item" role="menuitem" href="/?tag={{ t.q }}">
                      <span class="badge tag">{{ t.value }}</span>
                    </a>
                  {% endfor %}
                </div>
              </div>
            {% else %}
              <a href="/">All Volunteer Events</a>
            {% endif %}
            <a href="/my">My Signups</a>
            {% if currentUser %}
              {% if currentUser.impersonator %}
                <form method="post" action="/admin/impersonation/stop" style="display:inline">
                  <button class="btn" type="submit" style="padding:6px 10px">Stop Impersonating</button>
                </form>
              {% endif %}
              {% if currentUser.role == 'super_admin' %}
                <a href="/admin/dashboard">Admin</a>
              {% endif %}
              {% if currentUser.role == 'event_manager' %}
                <a href="/manager/dashboard">Manager</a>
              {% endif %}
              <form method="post" action="/logout" style="display:inline">
                <button class="btn" type="submit" style="padding:6px 10px">Logout</button>
              </form>
            {% else %}
              {% if navAddEventOnly %}
                <a href="/add-event">Add Event</a>
              {% else %}
                <a href="/admin/login">Admin</a>
                <a href="/manager/login">Manager</a>
              {% endif %}
            {% endif %}
          </div>
        </nav>
      </div>
    </header>
    <main class="wrap">
      {% block content %}{% endblock %}
    </main>
    <script>
      (function () {
        function toggle(btn) {
          var wrap = btn && btn.closest && btn.closest('.pw');
          if (!wrap) return;
          var input = wrap.querySelector('input');
          if (!input) return;
          var showing = input.type === 'text';
          input.type = showing ? 'password' : 'text';
          btn.textContent = showing ? 'Show' : 'Hide';
          btn.setAttribute('aria-label', showing ? 'Show password' : 'Hide password');
        }
        document.addEventListener('click', function (e) {
          var t = e.target;
          if (t && t.matches && t.matches('[data-pw-toggle]')) toggle(t);
        });
      })();
    </script>
  </body>
</html>
