{% extends "layout.njk" %}
{% block content %}
  <h1>Admin Dashboard</h1>
  {% if error %}
    <div class="flash err"><div>{{ error }}</div></div>
  {% endif %}
  {% if ok %}
    <div class="flash ok"><div>{{ ok }}</div></div>
  {% endif %}
  <div class="grid">
    <div class="panel">
      <div class="label">Events</div>
      <div class="title" style="font-size:28px">{{ stats.events }}</div>
    </div>
    <div class="panel">
      <div class="label">Upcoming shifts (14d)</div>
      <div class="title" style="font-size:28px">{{ stats.upcomingShifts }}</div>
    </div>
    <div class="panel">
      <div class="label">Signups (30d)</div>
      <div class="title" style="font-size:28px">{{ stats.signups30d }}</div>
    </div>
  </div>

  <div class="panel" style="margin-top:16px">
    <div class="actions">
      <a class="btn primary" href="/admin/users">Manage Users</a>
      <a class="btn" href="/admin/manager-orgs">Manager Org Assignments</a>
      <a class="btn" href="/admin/organizations">Organizations</a>
      <a class="btn" href="/admin/events">Events</a>
    </div>
  </div>

  <div class="panel" style="margin-top:16px">
    <div class="title">Impersonate manager</div>
    <form class="form" method="post" action="/admin/impersonate" style="margin-top:10px">
      <label>
        <span>Manager name or email</span>
        <input name="query" required maxlength="120" placeholder="e.g. Alex Smith or alex@example.com" />
      </label>
      <div class="actions">
        <button class="btn primary" type="submit">Go to Manager Dashboard</button>
      </div>
    </form>
  </div>

  <div class="panel" style="margin-top:16px">
    <div class="title">Recent login audit</div>
    {% if recentLoginAudit.length == 0 %}
      <p class="muted" style="margin-top:10px">No login attempts recorded yet.</p>
    {% else %}
      <div class="table" style="margin-top:12px">
        <div class="trow thead" style="grid-template-columns:1.2fr 0.8fr 0.7fr 1fr 1fr">
          <div>When</div>
          <div>Role</div>
          <div>Result</div>
          <div>User</div>
          <div>IP</div>
        </div>
        {% for row in recentLoginAudit %}
          <div class="trow" style="grid-template-columns:1.2fr 0.8fr 0.7fr 1fr 1fr">
            <div>
              <div>{{ row.createdAt }}</div>
              {% if row.userAgent %}<div class="muted">{{ row.userAgent }}</div>{% endif %}
            </div>
            <div>{{ row.role or 'unknown' }}</div>
            <div>{% if row.success %}Success{% else %}Failed{% endif %}</div>
            <div>
              <div>{% if row.userDisplayName %}{{ row.userDisplayName }}{% else %}Unknown user{% endif %}</div>
              <div class="muted">{{ row.email }}</div>
            </div>
            <div>{{ row.ipAddress or 'n/a' }}</div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="panel" style="margin-top:16px">
    <div class="title">Recent impersonation audit</div>
    {% if recentImpersonationAudit.length == 0 %}
      <p class="muted" style="margin-top:10px">No impersonation sessions recorded yet.</p>
    {% else %}
      <div class="table" style="margin-top:12px">
        <div class="trow thead" style="grid-template-columns:1.1fr 1fr 1fr 0.8fr 0.8fr">
          <div>Started</div>
          <div>Admin</div>
          <div>Manager</div>
          <div>Ended</div>
          <div>IP</div>
        </div>
        {% for row in recentImpersonationAudit %}
          <div class="trow" style="grid-template-columns:1.1fr 1fr 1fr 0.8fr 0.8fr">
            <div>
              <div>{{ row.startedAt }}</div>
              {% if row.userAgent %}<div class="muted">{{ row.userAgent }}</div>{% endif %}
            </div>
            <div>
              <div>{{ row.adminDisplayName }}</div>
              <div class="muted">{{ row.adminEmail }}</div>
            </div>
            <div>
              <div>{{ row.managerDisplayName }}</div>
              <div class="muted">{{ row.managerEmail }}</div>
            </div>
            <div>{{ row.endedAt or 'Active' }}</div>
            <div>{{ row.ipAddress or 'n/a' }}</div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
{% endblock %}
