{% extends "layout.njk" %}
{% block content %}
  <h1>Create Event</h1>
  {% if error %}
    <div class="flash err"><div>{{ error }}</div></div>
  {% endif %}

  <div class="panel">
    <form class="form" method="post" action="/manager/events/new">
      <input type="hidden" name="csrfToken" value="{{ csrfToken }}" />
      <label>
        <span>Title</span>
        <input name="title" required maxlength="200" />
      </label>
      <label>
        <span>Organization</span>
        <select name="organizationId" required>
          <option value="" disabled selected>Select…</option>
          {% for o in orgs %}
            <option value="{{ o.id }}">{{ o.name }}</option>
          {% endfor %}
        </select>
      </label>
      <label>
        <span>Featured?</span>
        <input type="checkbox" name="isFeatured" />
      </label>
      <label>
        <span>Tags (comma-separated)</span>
        <input name="tags" maxlength="500" placeholder="e.g. food, outdoors, community" />
      </label>
      <label>
        <span>Date</span>
        <input name="date" type="date" required />
      </label>
      <label>
        <span>Confirmation email note (optional)</span>
        <textarea name="confirmationEmailNote" rows="4" maxlength="2000" placeholder="This message will be included in the volunteer’s signup confirmation email."></textarea>
      </label>
      <label>
        <span>Description</span>
        <textarea name="description" rows="6" placeholder="Details for volunteers…"></textarea>
      </label>
      <div class="grid2">
        <label>
          <span>Location name</span>
          <input name="locationName" maxlength="200" />
        </label>
        <label>
          <span>Google Maps URL</span>
          <input name="locationMapUrl" maxlength="500" />
        </label>
      </div>
      <div class="actions">
        <button class="btn primary" type="submit">Create Draft</button>
        <a class="btn" href="/manager/events">Cancel</a>
      </div>
    </form>
  </div>
{% endblock %}
