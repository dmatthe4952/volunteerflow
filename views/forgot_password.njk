{% extends "layout.njk" %}
{% block content %}
  <h1>Forgot Password</h1>
  <div class="panel">
    {% if role == 'admin' %}
      <p class="muted">Admin passwords can’t be reset automatically yet.</p>
      <p class="muted">Please contact another Super Admin or the system operator to reset your password.</p>
    {% elseif role == 'manager' %}
      <p class="muted">Manager passwords can’t be reset automatically yet.</p>
      <p class="muted">Please contact a Super Admin or the system operator to reset your password.</p>
    {% else %}
      <p class="muted">Passwords can’t be reset automatically yet.</p>
      <p class="muted">Please contact the system operator to reset your password.</p>
    {% endif %}

    <details style="margin-top:12px">
      <summary class="btn">Operator instructions</summary>
      <div class="muted" style="margin-top:10px">
        Run <code>npm run set-password</code> on the server (see <code>OPERATORS_MANUAL.md</code>).
      </div>
    </details>

    <div class="actions" style="margin-top:12px">
      <a class="btn" href="/sign-in">Back</a>
    </div>
  </div>
{% endblock %}

