# LocalShifts admin convenience snippet (bash)
#
# Purpose: make $ADMIN_TOKEN available in your shell for ops endpoints like:
#   curl -H "x-admin-token: $ADMIN_TOKEN" ...
#
# Usage (recommended):
# 1) Copy to repo root as `codeSnippetForbashrc` and edit paths if needed:
#      cp deploy/shell/codeSnippetForbashrc.example ./codeSnippetForbashrc
# 2) Lock it down:
#      chmod 600 ./codeSnippetForbashrc
# 3) Source it from your ~/.bashrc:
#      echo 'test -f ~/projects/localshifts/codeSnippetForbashrc && . ~/projects/localshifts/codeSnippetForbashrc' >> ~/.bashrc
#
# Notes:
# - Keep this file OUT of git (repo .gitignore ignores `codeSnippetForbashrc`).
# - This reads only ADMIN_TOKEN from `.env.staging` (does not export DB credentials).

set -o allexport 2>/dev/null || true

LS_REPO_DIR="${LS_REPO_DIR:-$HOME/projects/localshifts}"
LS_ENV_FILE="${LS_ENV_FILE:-$LS_REPO_DIR/.env.staging}"

if [ -f "$LS_ENV_FILE" ]; then
  ADMIN_TOKEN="$(grep -E '^ADMIN_TOKEN=' "$LS_ENV_FILE" | head -n 1 | cut -d= -f2-)"
  export ADMIN_TOKEN
fi

unset LS_REPO_DIR LS_ENV_FILE
set +o allexport 2>/dev/null || true
