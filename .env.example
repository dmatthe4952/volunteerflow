# Core
APP_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
APP_TIMEZONE=America/New_York

# Database
DATABASE_URL=postgres://localshifts:localshifts_password@localhost:5432/localshifts

# Security
SESSION_SECRET=replace-with-64-char-random

# SMTP (optional for local dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=LocalShifts
SMTP_FROM_EMAIL=no-reply@example.com

# Dev-only local MTA (optional)
# If SMTP_HOST is blank, development mode logs emails to stdout by default.
# To actually send via the system MTA, opt in:
# EMAIL_TRANSPORT=sendmail
# SENDMAIL_PATH=/usr/sbin/sendmail

# Uploads
UPLOAD_MAX_BYTES=5242880
